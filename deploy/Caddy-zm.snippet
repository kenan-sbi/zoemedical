# ALTERNATIVE to the nginx block, if the admin prefers to route the subdomain through Caddy
# (Caddy is already running on the box and does automatic HTTPS — no certbot needed).
# Append this to the box's Caddyfile, then: sudo systemctl reload caddy

zm.zoepulse.pro {
    reverse_proxy 127.0.0.1:3010
    request_body {
        max_size 50MB          # allow large document/photo uploads
    }
}
