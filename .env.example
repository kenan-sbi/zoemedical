# Local dev config. Copy to .env and fill in. Synthetic data only — no real PHI locally.

# Postgres (matches docker-compose.yml / brew services)
DATABASE_URL="postgresql://postgres:dev@localhost:5432/medintel"

# Redis (matches docker-compose.yml / brew services)
REDIS_URL="redis://localhost:6379"

# ---------- LLM providers (the swappable seam) ----------
# Default provider for every role. 'mock' = free, offline, no keys (build the whole app LLM-free).
# Switch the whole pipeline with one line, or override per role below.
LLM_PROVIDER=mock                 # mock | ollama | gemini
# READER_PROVIDER=gemini          # per-role overrides (extraction)
# VERIFIER_PROVIDER=mock          # per-role overrides (cross-check — keep DIFFERENT from Reader)
# ANALYZER_PROVIDER=gemini        # per-role overrides (chat + drafting)
VERIFIER_ENABLED=1                # 1 = run the 2nd-model cross-check (doubles LLM calls when paid)

# Local open model (free) — run `ollama serve` after `ollama pull qwen2.5`
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5

# Gemini (real, paid/free-tier) — used only when a role routes to 'gemini'
GEMINI_API_KEY=""
# GEMINI_MODEL=gemini-2.5-flash   # default; set gemini-2.5-pro for higher-fidelity extraction

# ---------- OCR provider (the other swappable seam) ----------
OCR_PROVIDER=builtin              # builtin (.txt + text PDFs) | stub (bypass). Real OCR plugs in here.

# ---------- Auth ----------
# For LOCAL dev only, DEV_NO_AUTH=1 bypasses Supabase auth. NEVER set in any real deployment.
DEV_NO_AUTH=1
SUPABASE_URL=""
SUPABASE_ANON_KEY=""

# ---------- Doctor Console (hair-transplant pre-consult tool) ----------
DOCTOR_PASSCODE="change-me"       # passcode gate for /console

# ================= SERVERLESS / VERCEL (production) =================
# Local dev needs NONE of the below (files -> ./uploads on disk, jobs -> local worker + Redis).
# On Vercel there is no disk and no always-on worker, so set these there:
#
# 1) Object storage — bytes go to Supabase Storage instead of local disk when the service key is set.
# SUPABASE_SERVICE_ROLE_KEY=""    # Supabase -> Project Settings -> API -> service_role (SECRET, server-only)
# SUPABASE_STORAGE_BUCKET=documents   # create this bucket (Private) in Supabase Storage
#
# 2) No worker on Vercel: leave REDIS_URL UNSET so uploads are processed inline via waitUntil.
#
# 3) DATABASE_URL on Vercel should be the Supabase *Transaction* pooler (port 6543) for serverless:
#    postgresql://postgres.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true&connection_limit=1
#
# 4) DEV_NO_AUTH=0 in production (real Supabase auth). Set a strong DOCTOR_PASSCODE.
# 5) PUPPETEER_SKIP_DOWNLOAD=true  (Vercel build env — skips the Chromium download; PDF export is
#    auto-disabled on Vercel anyway).
