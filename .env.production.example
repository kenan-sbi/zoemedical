# Copy to .env.production on the Hetzner box and fill in real values. NEVER commit the real file.
# Postgres is Supabase (external). Redis is provided by docker-compose (do not set REDIS_URL here —
# compose injects redis://redis:6379). Files persist on the `uploads` docker volume (local backend),
# so Supabase Storage is NOT needed on Hetzner — leave SUPABASE_SERVICE_ROLE_KEY unset.

# --- Database (Supabase session pooler, IPv4) ---
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require"

# --- LLM ---
LLM_PROVIDER=gemini
GEMINI_API_KEY=""
GEMINI_MODEL=gemini-2.5-flash
VERIFIER_PROVIDER=mock          # set to a DIFFERENT real model (e.g. gemini) to enable "verified" badges (2x cost)
VERIFIER_ENABLED=1
OCR_PROVIDER=builtin

# --- Auth ---
# Demo: DEV_NO_AUTH=1 = no login wall (guard the URL). Production: set 0 and wire Supabase auth.
DEV_NO_AUTH=1
SUPABASE_URL="https://<ref>.supabase.co"
SUPABASE_ANON_KEY=""
# SUPABASE_SERVICE_ROLE_KEY=   # leave UNSET on Hetzner -> files use the local uploads volume

# --- Doctor Console ---
DOCTOR_PASSCODE="set-a-strong-passcode"
